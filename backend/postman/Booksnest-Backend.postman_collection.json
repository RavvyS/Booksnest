    {
      "name": "Comments",
      "item": [
        {
          "name": "Create Comment (Reader)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', function () { pm.response.to.have.status(201); });",
                  "const data = pm.response.json();",
                  "if (data._id) pm.environment.set('commentId', data._id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{readerToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Great resource!\",\n  \"materialId\": \"{{materialId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/comments",
              "host": ["{{baseUrl}}"],
              "path": ["api", "comments"]
            }
          },
          "response": []
        },
        {
          "name": "Get Comments By Material",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/comments?materialId={{materialId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "comments"],
              "query": [{ "key": "materialId", "value": "{{materialId}}" }]
            }
          },
          "response": []
        },
        {
          "name": "Update Comment (Owner Reader)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{readerToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Updated by owner\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/comments/{{commentId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "comments", "{{commentId}}"]
            }
          },
          "response": []
        },
        {
          "name": "Update Comment (Non-Owner Author, expect 403)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authorToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Trying unauthorized update\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/comments/{{commentId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "comments", "{{commentId}}"]
            }
          },
          "response": []
        },
        {
          "name": "Delete Comment (Librarian override)",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{librarianToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/comments/{{commentId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "comments", "{{commentId}}"]
            }
          },
          "response": []
        }
      ]
