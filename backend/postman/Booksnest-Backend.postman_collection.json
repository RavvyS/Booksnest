    {
      "name": "Books",
      "item": [
        {
          "name": "Create Book with PDF (Librarian)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', function () { pm.response.to.have.status(201); });",
                  "const data = pm.response.json();",
                  "if (data.id) pm.environment.set('bookId', data.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{librarianToken}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title", "value": "Clean Code", "type": "text" },
                { "key": "author", "value": "Robert C. Martin", "type": "text" },
                { "key": "isbn", "value": "978-0-13-235088-4", "type": "text" },
                { "key": "totalCopies", "value": "2", "type": "text" },
                { "key": "description", "value": "A handbook of agile software craftsmanship", "type": "text" },
                { "key": "file", "type": "file", "src": "" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/books",
              "host": ["{{baseUrl}}"],
              "path": ["api", "books"]
            }
          },
          "response": []
